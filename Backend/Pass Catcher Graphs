import nflreadpy as nfl
import polars as pl
import matplotlib.pyplot as plt

def pick_col(df, candidates):
    for c in candidates:
        if c in df.columns:
            return c
    return None

def resolve_player(df, player_query, name_col, id_col):
    """
    Find one unique player using exact name match first, then partial match.
    Returns (player_id, player_name).
    """
    q = player_query.strip().lower()

    exact = (
        df.filter(
            pl.col(name_col)
            .fill_null("")
            .str.to_lowercase()
            == q
        )
        .select([name_col, id_col])
        .unique()
    )

    if exact.height == 1:
        row = exact.row(0)
        return row[1], row[0]

    if exact.height > 1:
        raise ValueError(
            f"Multiple exact matches found for '{player_query}':\n{exact}"
        )

    partial = (
        df.filter(
            pl.col(name_col)
            .fill_null("")
            .str.to_lowercase()
            .str.contains(q, literal=False)
        )
        .select([name_col, id_col])
        .unique()
    )

    if partial.height == 1:
        row = partial.row(0)
        return row[1], row[0]

    if partial.height > 1:
        raise ValueError(
            f"Multiple partial matches found for '{player_query}'. "
            f"Use a fuller name or a player ID.\n{partial}"
        )

    raise ValueError(f"No player found for '{player_query}'.")

def plot_player_season_totals(df, player_id, player_name, id_col, stat_col, title, ylabel):
    player = (
        df.filter(pl.col(id_col) == player_id)
        .group_by("season")
        .agg(pl.col(stat_col).sum().alias(stat_col))
        .sort("season")
    )

    if player.height == 0:
        raise ValueError(f"No season totals found for '{player_name}'.")

    pdf = player.to_pandas()

    plt.figure(figsize=(9, 5))
    plt.plot(pdf["season"], pdf[stat_col], marker="o")
    plt.xticks(
        ticks=pdf["season"],
        labels=[str(int(x)) for x in pdf["season"]]
    )
    plt.title(title)
    plt.xlabel("Season")
    plt.ylabel(ylabel)
    plt.grid(True)
    plt.tight_layout()
    plt.show()

    return player

